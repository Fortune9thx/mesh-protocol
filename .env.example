DATABASE_URL=postgresql://mesh:mesh@localhost:5432/mesh_protocol
REDIS_URL=redis://localhost:6379
PORT=3100
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# AI Provider — set AI_PROVIDER=openai with a real key for live LLM calls.
# AI_PROVIDER=mock uses canned responses (demo/test only).
AI_PROVIDER=mock
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini

# GenLayer — Bradbury Testnet
# Deployed contract addresses (2026-07-04):
#   AgentRegistry:     0xB31900eE7fa37E7e8a2cd49212125e49efdBEa2c
#   IntentRegistry:    0x4a2CB695c015F4198627135249a093425a5080e8
#   NegotiationEngine: 0xa5C8cd99d081145ef90dDEEC024665CaA21E86C7
#   EscrowVault:       0x7Db590E16F1F2E40d0859379b2706fc539db5d65
#   ReputationLedger:  0xfA8912C4AA206DdAD7496Cf3df5B6A64AF1e5982
# Export key: npx genlayer account export --account <name> --output key.json --password "<pass>"
GENLAYER_RPC_URL=https://rpc-bradbury.genlayer.com
GENLAYER_PRIVATE_KEY=0x...

# Security — REQUIRED in production. Server refuses to start with the default value.
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=change-me-in-production
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
