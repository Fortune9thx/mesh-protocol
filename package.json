{
  "name": "mesh-protocol",
  "version": "0.1.0",
  "description": "Coordination layer for the autonomous agent economy",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('backend/src/db/migrations','backend/dist/backend/src/db/migrations',{recursive:true})\"",
    "dev": "tsx watch backend/src/server.ts",
    "start": "node backend/dist/backend/src/db/migrate.js && node backend/dist/backend/src/server.js",
    "migrate": "tsx backend/src/db/migrate.ts",
    "seed": "tsx backend/src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo": "tsx demo/run-demo.ts",
    "lint": "eslint backend/src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "genlayer-js": "^1.1.8",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.0",
    "viem": "^2.54.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.17.0",
    "puppeteer": "^25.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
